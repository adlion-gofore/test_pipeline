                <mxCell id="app" value="&lt;b&gt;Application / Python&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#5a6b7a&quot;&gt;PyO3 + maturin Python bindings expose UdsClient and all service methods via pyo3-asyncio (tokio runtime)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;" parent="1" vertex="1">
