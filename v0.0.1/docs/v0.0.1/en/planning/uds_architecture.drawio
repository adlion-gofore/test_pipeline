                <mxCell id="transport" value="&lt;b&gt;Transport Abstraction (Rust Trait)&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#5a6b7a&quot;&gt;&lt;i&gt;async fn send(&amp;amp;mut self, data: &amp;amp;[u8]) → Result&amp;lt;&amp;gt;&lt;/i&gt;&amp;nbsp;&amp;nbsp;·&amp;nbsp;&amp;nbsp;&lt;i&gt;async fn receive(&amp;amp;mut self) → Result&amp;gt;&lt;/i&gt;&lt;br&gt;Any type implementing this trait can serve as transport. Enables mock transport for unit testing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;verticalAlign=middle;" parent="1" vertex="1">
