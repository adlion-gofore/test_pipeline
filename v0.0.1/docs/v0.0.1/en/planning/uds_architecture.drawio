                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="session" value="&lt;b&gt;UDS Session Manager&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#5a6b7a&quot;&gt;Tracks active session state (Default / Programming / Extended). Sends TesterPresent heartbeat as background tokio task. Transparent to callers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;" parent="1" vertex="1">
